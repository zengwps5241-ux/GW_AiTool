# Cookie 签名密钥(部署时务必改成随机长串)
APP_SECRET=change-me-in-prod-please

# Claude 接入(旧单供应商配置仍兼容)
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# 智谱 Web Search MCP(可选):配置后会内置给 Claude Agent 使用
ZHIPU_WEB_SEARCH_API_KEY=

# Claude Agent 多供应商配置(推荐):新增兼容供应商时按相同前缀追加即可
# 前端只展示 MODELS 中的模型名，不展示供应商 key
#
# GLM —— 复用 Anthropic 兼容网关(如 openapi.cloud-ai.cn)
# ANTHROPIC_PROVIDER_GLM_AUTH_TOKEN=
# ANTHROPIC_PROVIDER_GLM_BASE_URL=https://openapi.cloud-ai.cn
# ANTHROPIC_PROVIDER_GLM_MODELS=["glm-5.2","glm-5.1"]
#
# DeepSeek —— 官方 Anthropic 兼容端点(/anthropic),claude-agent-sdk 可直接调用;
# 同一 DeepSeek token 也会被会话标题/意图分类复用(走 OpenAI 兼容端点)
# ANTHROPIC_PROVIDER_DEEPSEEK_AUTH_TOKEN=
# ANTHROPIC_PROVIDER_DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_PROVIDER_DEEPSEEK_MODELS=["deepseek-v4-flash","deepseek-v4-pro"]
#
# ANTHROPIC_PROVIDER_MINIMAX_AUTH_TOKEN=
# ANTHROPIC_PROVIDER_MINIMAX_BASE_URL=
# ANTHROPIC_PROVIDER_MINIMAX_MODELS=["MiniMax-M2.7-highspeed"]

# 数据库连接(必填)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gokagent

# Redis 连接与团队空间文件锁配置
REDIS_URL=redis://localhost:6379/0
TEAM_SPACE_FILE_LOCK_TTL_SECONDS=1800
TEAM_SPACE_FILE_LOCK_CLEANUP_GRACE_SECONDS=300

# 可选:覆盖默认目录位置(相对路径基于 backend/ 工作目录)
# WORKSPACES_DIR=user_workspaces
# CLAUDE_DATA_DIR=claude_data
# AGENT_WORKDIRS_DIR=agent_workspaces
# FEEDBACK_UPLOADS_DIR=feedback_uploads

# 企业微信配置(必填)
# WECHAT_WORK_CORP_ID=
# WECHAT_WORK_AGENT_ID=
# WECHAT_WORK_SECRET=
#qrcode 自行构建二维码（可获取手机号等隐私数据），sso 企微的扫码登录
WECHAT_WORK_LOGIN_MODE=sso

#mineru
#MINERU_API_URL=http://192.168.125.11:8000/file_parse
#MINERU_MAX_CONCURRENT_REQUESTS=2

# Office 预览: kkFileView 仅由后端内网访问,不要暴露给用户浏览器
# APP_INTERNAL_BASE_URL=http://backend:8000
# KKFILEVIEW_BASE_URL=http://192.168.125.180:8012

# APP_ENV=production
